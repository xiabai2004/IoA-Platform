# IoA 平台环境变量配置模板
# 复制此文件为 .env 并填入真实值
# cp .env.example .env

# ====================
# LLM API 密钥
# ====================

# DeepSeek API 密钥（必需）
DEEPSEEK_API_KEY=sk-your-deepseek-api-key-here

# 阿里云通义千问 API 密钥（可选，作为备选 Provider）
QWEN_API_KEY=your-qwen-api-key-here

# ====================
# 认证配置
# ====================

# 预共享密钥（用于 Agent 认证）
# 生成方式: python -c "import secrets; print(secrets.token_urlsafe(32))"
IOA_PSK=your-pre-shared-key-here

# ====================
# 服务配置
# ====================

# 中间件端口（默认 8000）
# MIDDLEWARE_PORT=8000

# 模拟器端口（默认 8001）
# SIMULATOR_PORT=8001

# ====================
# 数据库配置
# ====================

# SQLite 数据库路径（默认 data/ioa.db）
# DATABASE_PATH=data/ioa.db

# ====================
# 日志配置
# ====================

# 日志级别: DEBUG, INFO, WARNING, ERROR
# LOG_LEVEL=INFO
