# IoA Distributed Network Ops Platform — Environment Configuration
# Copy this file to .env and fill in your actual values.
# NEVER commit .env to version control.

# ==================== Security ====================
# Generate a strong PSK:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
IOA_PSK=generate-with-python-secrets-token-urlsafe-32

# ==================== LLM API Keys ====================
DEEPSEEK_API_KEY=your-deepseek-api-key-here
MIMO_API_KEY=your-mimo-api-key-here

# ==================== Deployment ====================
# "production" | "development"
IOA_ENV=development

# "memory" (single process, dev) | "nats" (distributed, prod)
IOA_BUS_BACKEND=nats

# NATS server URL (only used when IOA_BUS_BACKEND=nats)
NATS_SERVERS=nats://nats:4222

# ==================== Service Ports ====================
MIDDLEWARE_PORT=8000
SIMULATOR_PORT=8001
GUI_PORT=3000
